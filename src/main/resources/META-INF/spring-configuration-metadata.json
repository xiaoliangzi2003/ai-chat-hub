{
  "properties": [
    {
      "name": "jwt.secret",
      "type": "java.lang.String",
      "description": "JWT签名密钥",
      "defaultValue": ""
    },
    {
      "name": "jwt.expiration",
      "type": "java.lang.Integer",
      "description": "JWT过期时间(秒)",
      "defaultValue": 7200
    },
    {
      "name": "app.security.password-max-retry",
      "type": "java.lang.Integer",
      "description": "密码最大重试次数",
      "defaultValue": 5
    },
    {
      "name": "app.security.lock-duration",
      "type": "java.lang.Integer",
      "description": "账号锁定时长(秒)",
      "defaultValue": 3600
    },
    {
      "name": "app.security.code-expire",
      "type": "java.lang.Integer",
      "description": "验证码过期时间(秒)",
      "defaultValue": 300
    },
    {
      "name": "app.security.code-resend-interval",
      "type": "java.lang.Integer",
      "description": "验证码重发间隔(秒)",
      "defaultValue": 60
    }
  ]
}